# Umbra HTTP APIs (browser — must be prefixed NEXT_PUBLIC_)
# NEXT_PUBLIC_UMBRA_INDEXER_URL=https://utxo-indexer.api-devnet.umbraprivacy.com
# NEXT_PUBLIC_UMBRA_RELAYER_URL=https://relayer.api-devnet.umbraprivacy.com

# Supabase Storage (merchant uploads: product images, store logos)
#
# Project URL (NOT the database pooler host): Dashboard →⚙ Project Settings → API
# → "Project URL" (https://xxxxxxxx.supabase.co)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
#
# Server key (pick ONE format — both work for uploads):
#   • Legacy JWT service_role (starts with eyJ...) — SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SECRET_KEY
#   • New secret key (sb_secret_...) — same vars; we use Storage REST with apikey header only (avoids JWS errors)
#
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=
#
# Bucket name (create in Storage; set public for storefront image URLs)
# SUPABASE_STORAGE_BUCKET=store-uploads

# Storefront subdomain (optional). DNS: wildcard *.store.unseen.finance → your app.
# Example: NEXT_PUBLIC_STORE_BASE_HOST=store.unseen.finance → https://{slug}.store.unseen.finance/
# Dev: use something that resolves to 127.0.0.1, e.g. store.lvh.me → http://{slug}.store.lvh.me:3000/
# NEXT_PUBLIC_STORE_BASE_HOST=store.unseen.finance
# Optional duplicate for Edge middleware (defaults to NEXT_PUBLIC_* if unset)
# STORE_BASE_HOST=store.unseen.finance
