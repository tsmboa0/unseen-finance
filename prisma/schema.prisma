generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Merchant ────────────────────────────────────────────────────────────────
// A registered business that accepts Unseen Pay payments.
// Created when a user signs up on the dashboard via Privy.

model Merchant {
  id            String   @id @default(cuid())
  privyId       String?  @unique   // Privy user ID (bound on first login)
  name          String
  businessSize  String?
  industry      String?
  country       String?
  handle        String?
  ownerName     String?
  email         String?  @unique
  timezone      String   @default("Africa/Lagos")
  walletAddress String?  @unique   // Solana pubkey (base58)
  apiKey        String   @unique   // usk_live_... or usk_test_... (primary key)
  apiKeyPrefix  String             // first 16 chars shown in dashboard
  network       String   @default("devnet")  // "mainnet" | "devnet"
  plan          String   @default("Starter")
  kybStatus     String   @default("Pending")
  webhookUrl    String?
  webhookSecret String?            // HMAC-SHA256 signing secret
  /// True after the merchant completes Umbra on-chain registration (encrypted + anonymous) for walletAddress.
  umbraRegistered   Boolean   @default(false)
  umbraRegisteredAt DateTime?
  onboardingCompletedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  payments Payment[]
  apiKeys  ApiKeyRecord[]
  stores   Store[]
  umbraScanCursors UmbraUtxoScanCursor[]
  umbraUtxos UmbraMerchantUtxo[]
  dashboardEvents DashboardEvent[]
}

// ─── ApiKeyRecord ────────────────────────────────────────────────────────────
// Multiple API keys per merchant. The full key is only shown once on creation.
// We store a SHA-256 hash for lookup and the prefix for display.

model ApiKeyRecord {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String          // Human-readable label (e.g. "Production server")
  prefix      String          // First 16 chars (e.g. "usk_test_9pK2…")
  hashedKey   String @unique  // SHA-256 hash of the full key (for lookup)
  environment String          // "test" | "live"
  scopes      String          // JSON array string (e.g. '["gateway.write","webhooks"]')
  status      String @default("active")  // "active" | "revoked"
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchantId])
  @@index([hashedKey])
}

// ─── Payment ─────────────────────────────────────────────────────────────────
// A single payment session created by a merchant.
// Lifecycle: PENDING → CONFIRMED (or EXPIRED / CANCELLED)

model Payment {
  id         String        @id @default(cuid())
  merchantId String
  merchant   Merchant      @relation(fields: [merchantId], references: [id])

  // Payment request
  amount      BigInt        // raw token units (e.g. USDC 6 decimals)
  mint        String        // SPL token mint address
  reference   String        // merchant's own order / invoice ID
  description String?
  metadata    String?       // JSON string (SQLite has no Json type)

  // On-chain verification
  // Submitted by the checkout page after the user signs the createUtxo tx
  txSignature     String?   // legacy single base58 Solana tx signature
  txSignatures    String?   // JSON string array of base58 signatures returned by Umbra createUtxo
  submittedAmount BigInt?   // amount the checkout page reported
  expectedOptionalDataHash  String? // sha256 hash (hex) derived from payment context; used for deterministic tx binding
  submittedOptionalDataHash String? // hash (hex) reported by hosted checkout for the submitted createUtxo

  // Redirect / webhook URLs
  successUrl String?
  cancelUrl  String?
  webhookUrl String?        // overrides merchant.webhookUrl for this session

  // Status & lifecycle
  status      String   @default("PENDING")  // PENDING|CONFIRMED|EXPIRED|CANCELLED
  expiresAt   DateTime
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([reference])
  @@index([createdAt])
}

// ─── Store ───────────────────────────────────────────────────────────────────
// A merchant's e-commerce storefront. Each store has its own slug for the
// public URL: /store/[slug] (dev) or storename.store.unseen.finance (prod).

model Store {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String
  slug        String   @unique   // URL path identifier
  category    String?             // e.g. "Digital goods", "Merch", "SaaS"
  description String?
  logoUrl     String?
  currency    String   @default("USDC")  // "USDC" | "SOL"
  privacy     String   @default("shielded")  // "shielded" | "public"
  status      String   @default("draft")     // "draft" | "live" | "paused"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  orders   Order[]

  @@index([merchantId])
  @@index([slug])
}

// ─── Product ─────────────────────────────────────────────────────────────────
// An item listed in a store. Price is in raw token units.

model Product {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name      String
  shortDesc String?
  longDesc  String?
  price     BigInt          // raw token units
  mint      String          // inherits from store, but can be overridden
  imageUrl  String?
  sku       String?
  stock     Int?            // null = unlimited
  status    String   @default("active")  // "active" | "archived"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([storeId, status])
}

// ─── Order ───────────────────────────────────────────────────────────────────
// Links a storefront purchase to a Payment session.

model Order {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id])

  customerEmail String?
  items         String          // JSON string: [{productId, name, qty, price}]
  totalAmount   BigInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeId])
  @@index([paymentId])
}

// ─── Umbra UTXO Scan Cursor ───────────────────────────────────────────────────
// Persists the dashboard's last scanned insertion index for a given merchant wallet.
// This allows UTXO scanning to resume across refreshes and devices.

model UmbraUtxoScanCursor {
  id                String   @id @default(cuid())
  merchantId         String
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network            String   // "mainnet" | "devnet"
  walletAddress      String   // base58 (merchant.walletAddress)
  treeIndex          Int      @default(0)
  nextInsertionIndex Int      @default(0)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([merchantId, network, walletAddress])
  @@index([merchantId])
  @@index([walletAddress])
}

// ─── Umbra Merchant UTXOs ─────────────────────────────────────────────────────
// Durable list of scanned UTXOs for each merchant wallet, with claim state.
// This prevents older unclaimed UTXOs from disappearing in UI as scan cursor advances.

model UmbraMerchantUtxo {
  id             String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network         String
  walletAddress   String
  treeIndex       Int
  insertionIndex  Int
  amount          Float
  currency        String
  usdValue        Float
  sender          String?
  age             String?
  unlockerType    String?
  status          String   @default("claimable") // claimable | claiming | claimed | claim_failed
  claimTxSignature String?
  claimError      String?
  claimedAt       DateTime?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([merchantId, network, walletAddress, treeIndex, insertionIndex])
  @@index([merchantId, status])
  @@index([walletAddress, status])
}

// ─── Dashboard Event Stream ───────────────────────────────────────────────────
// Unified activity log for analytics/recent activity charts and feed.
model DashboardEvent {
  id           String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network       String
  walletAddress String?
  category      String   // payment | transfer | claim | shield | unshield | payroll | invoice | tiplinks | compliance
  direction     String   @default("in") // in | out
  status        String   @default("completed") // completed | pending | failed
  amount        Float
  currency      String
  counterparty  String?
  memo          String?
  txHash        String?
  metadata      String?
  createdAt     DateTime @default(now())

  @@index([merchantId, createdAt])
  @@index([merchantId, category])
}
