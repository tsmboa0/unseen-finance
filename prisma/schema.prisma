generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Merchant ────────────────────────────────────────────────────────────────
// A registered business that accepts Unseen Pay payments.
// Created when a user signs up on the dashboard via Privy.

model Merchant {
  id            String   @id @default(cuid())
  privyId       String?  @unique   // Privy user ID (bound on first login)
  name          String
  businessSize  String?
  industry      String?
  country       String?
  handle        String?
  ownerName     String?
  email         String?  @unique
  timezone      String   @default("Africa/Lagos")
  walletAddress String?  @unique   // Solana pubkey (base58)
  apiKey        String   @unique   // usk_live_... or usk_test_... (primary key)
  apiKeyPrefix  String             // first 16 chars shown in dashboard
  network       String   @default("devnet")  // "mainnet" | "devnet"
  plan          String   @default("Starter")
  kybStatus     String   @default("Pending")
  webhookUrl    String?
  webhookSecret String?            // HMAC-SHA256 signing secret
  /// True after the merchant completes Umbra on-chain registration (encrypted + anonymous) for walletAddress.
  umbraRegistered   Boolean   @default(false)
  umbraRegisteredAt DateTime?
  /// Last time the merchant completed Privy `addSigners` (app signer + payroll policy) in the dashboard.
  payrollPrivySignerConsentAt  DateTime?
  /// After this instant we show the payroll delegation explainer again before `addSigners` (server vs client clock skew is acceptable).
  payrollPrivySignerValidUntil DateTime?
  onboardingCompletedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  payments Payment[]
  apiKeys  ApiKeyRecord[]
  stores   Store[]
  umbraScanCursors UmbraUtxoScanCursor[]
  umbraUtxos UmbraMerchantUtxo[]
  dashboardEvents DashboardEvent[]
  payrollRuns   PayrollRun[]
  giftCards     GiftCard[]
  merchantInvoices MerchantInvoice[]
  complianceGrants ComplianceGrant[]
  complianceDisclosureReports ComplianceDisclosureReport[]
  umbraScopedViewingKeys UmbraScopedViewingKey[]
}

/// Umbra user-granted compliance grant metadata (on-chain PDA + optional auditor X25519).
model ComplianceGrant {
  id                  String    @id @default(cuid())
  merchantId          String
  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  label               String
  receiverWallet      String
  /// 64 hex chars (no 0x), auditor / receiver X25519 public key.
  receiverX25519Hex   String
  /// U128 nonce (RcEncryptionNonce) as decimal string — must match create/revoke txs.
  nonceDecimal        String
  status              String    @default("active") // active | revoked
  createTxSignature   String?
  revokeTxSignature   String?
  lastChainCheckAt    DateTime?
  lastChainCheckExists Boolean?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  revokedAt           DateTime?

  @@index([merchantId, status])
  @@index([merchantId, createdAt])
}

/// Merchant-issued confidential disclosure package (PDF) for auditors / regulators.
model ComplianceDisclosureReport {
  id              String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  title           String
  dateFrom        DateTime
  dateTo          DateTime
  txType          String   @default("all") // all | inflow | outflow
  /// JSON array of dashboard product slugs included in scope.
  productsJson    String
  recipientEmail  String?
  status          String   @default("ready") // generating | ready | expired
  generatedAt     DateTime @default(now())
  approxSizeBytes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([merchantId, createdAt])
}

/// Locally derived Umbra Poseidon viewing key (mint- and time-scoped). Sensitive — dashboard-auth only.
model UmbraScopedViewingKey {
  id           String   @id @default(cuid())
  merchantId   String
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  label        String
  /// mint | yearly | monthly | daily | hourly | minute | second
  scope        String
  mintAddress  String
  year         Int?
  month        Int?
  day          Int?
  hour         Int?
  minute       Int?
  second       Int?
  /// Fixed-width hex (64 nybbles) BN254 field element from Umbra SDK.
  keyHex       String
  createdAt    DateTime @default(now())

  @@index([merchantId, createdAt])
}

// ─── Gift cards (admin treasury → self-claimable UTXO → recipient public ATA) ───
model GiftCard {
  id                String    @id @default(cuid())
  merchantId        String
  merchant          Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network           String
  status            String    @default("pending_funding") // pending_funding | active | claimed | expired | funding_failed | claim_failed
  /// Face value (display units, e.g. 10.5 USDC).
  amountDisplay     Float
  /// Face value in raw units (USDC 6 decimals) — amount locked in the gift UTXO.
  faceAmountRaw     BigInt
  /// Total the merchant must fund (face + platform fee).
  fundAmountRaw     BigInt
  platformFeeRaw    BigInt
  mint              String
  memo              String
  claimCodeHash     String    @unique
  /// Plain claim code for merchant dashboard copy; null until funded & issued. Never expose on public APIs.
  claimCodePlain    String?
  expiresAt         DateTime
  fundingTxSig      String?
  createUtxoTxSig   String?
  claimTxSig        String?
  /// Ephemeral Umbra generation index (decimal string) used when creating the self-claimable UTXO.
  utxoGenerationIndex String?
  claimError        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  claimedAt         DateTime?
  activatedAt       DateTime?

  @@index([merchantId, createdAt])
  @@index([merchantId, status])
  @@index([status, expiresAt])
}

/// Per-wallet (hashed) Umbra scan floor so repeat gift redemptions skip already-claimed leaves.
/// Does not store recipient pubkey; key is sha256(pubkey|network).
model PublicGiftClaimCursor {
  id             String   @id @default(cuid())
  recipientKey   String
  network        String
  /// JSON map: tree index string → max claimed insertion index (decimal string).
  treeBaselines  Json     @default("{}")
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([recipientKey, network])
  @@index([network])
}

/// Merchant-issued invoice (line items + optional Payment for hosted checkout).
model MerchantInvoice {
  id               String    @id @default(cuid())
  merchantId       String
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  invoiceNumber    String
  status           String    @default("draft") // draft | sent | paid | overdue | cancelled
  clientName       String
  clientEmail      String?
  /// JSON array: { name, description?, quantity, unitPrice, lineTotal }
  lineItems        Json
  currency         String    @default("USDC")
  subtotalDisplay  Float
  totalAmountRaw   BigInt
  mint             String
  notes            String?
  dueAt            DateTime
  issuedAt         DateTime  @default(now())
  paymentId        String?   @unique
  payment          Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([merchantId, invoiceNumber])
  @@index([merchantId, status])
  @@index([merchantId, createdAt])
}

// ─── ApiKeyRecord ────────────────────────────────────────────────────────────
// Multiple API keys per merchant. The full key is only shown once on creation.
// We store a SHA-256 hash for lookup and the prefix for display.

model ApiKeyRecord {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String          // Human-readable label (e.g. "Production server")
  prefix      String          // First 16 chars (e.g. "usk_test_9pK2…")
  hashedKey   String @unique  // SHA-256 hash of the full key (for lookup)
  environment String          // "test" | "live"
  scopes      String          // JSON array string (e.g. '["gateway.write","webhooks"]')
  status      String @default("active")  // "active" | "revoked"
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchantId])
  @@index([hashedKey])
}

// ─── Payment ─────────────────────────────────────────────────────────────────
// A single payment session created by a merchant.
// Lifecycle: PENDING → CONFIRMED (or EXPIRED / CANCELLED)

model Payment {
  id         String        @id @default(cuid())
  merchantId String
  merchant   Merchant      @relation(fields: [merchantId], references: [id])

  // Payment request
  amount      BigInt        // raw token units (e.g. USDC 6 decimals)
  mint        String        // SPL token mint address
  reference   String        // merchant's own order / invoice ID
  description String?
  metadata    String?       // JSON string (SQLite has no Json type)

  // On-chain verification
  // Submitted by the checkout page after the user signs the createUtxo tx
  txSignature     String?   // legacy single base58 Solana tx signature
  txSignatures    String?   // JSON string array of base58 signatures returned by Umbra createUtxo
  submittedAmount BigInt?   // amount the checkout page reported
  expectedOptionalDataHash  String? // sha256 hash (hex) derived from payment context; used for deterministic tx binding
  submittedOptionalDataHash String? // hash (hex) reported by hosted checkout for the submitted createUtxo

  // Redirect / webhook URLs
  successUrl String?
  cancelUrl  String?
  webhookUrl String?        // overrides merchant.webhookUrl for this session

  // Status & lifecycle
  status      String   @default("PENDING")  // PENDING|CONFIRMED|EXPIRED|CANCELLED
  expiresAt   DateTime
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
  merchantInvoice MerchantInvoice?

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([reference])
  @@index([createdAt])
}

// ─── Store ───────────────────────────────────────────────────────────────────
// A merchant's e-commerce storefront. Each store has its own slug for the
// public URL: /store/[slug] (dev) or storename.store.unseen.finance (prod).

model Store {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  name        String
  slug        String   @unique   // URL path identifier
  category    String?             // e.g. "Digital goods", "Merch", "SaaS"
  description String?
  logoUrl     String?
  currency    String   @default("USDC")  // "USDC" | "SOL"
  privacy     String   @default("shielded")  // "shielded" | "public"
  status      String   @default("draft")     // "draft" | "live" | "paused"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  orders   Order[]

  @@index([merchantId])
  @@index([slug])
}

// ─── Product ─────────────────────────────────────────────────────────────────
// An item listed in a store. Price is in raw token units.

model Product {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name      String
  shortDesc String?
  longDesc  String?
  price     BigInt          // raw token units
  mint      String          // inherits from store, but can be overridden
  imageUrl  String?
  sku       String?
  stock     Int?            // null = unlimited
  status    String   @default("active")  // "active" | "archived"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([storeId, status])
}

// ─── Order ───────────────────────────────────────────────────────────────────
// Links a storefront purchase to a Payment session.

model Order {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id])

  customerName    String?
  customerEmail   String?
  shippingAddress String?   // JSON: {addressLine, city, country, postalCode}
  items           String    // JSON string: [{productId, name, qty, price}]
  totalAmount     BigInt
  deliveryStatus  String   @default("received")  // "received" | "delivered"
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([paymentId])
}

// ─── Umbra UTXO Scan Cursor ───────────────────────────────────────────────────
// Persists the dashboard's last scanned insertion index for a given merchant wallet.
// This allows UTXO scanning to resume across refreshes and devices.

model UmbraUtxoScanCursor {
  id                String   @id @default(cuid())
  merchantId         String
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network            String   // "mainnet" | "devnet"
  walletAddress      String   // base58 (merchant.walletAddress)
  treeIndex          Int      @default(0)
  nextInsertionIndex Int      @default(0)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@unique([merchantId, network, walletAddress])
  @@index([merchantId])
  @@index([walletAddress])
}

// ─── Umbra Merchant UTXOs ─────────────────────────────────────────────────────
// Durable list of scanned UTXOs for each merchant wallet, with claim state.
// This prevents older unclaimed UTXOs from disappearing in UI as scan cursor advances.

model UmbraMerchantUtxo {
  id             String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network         String
  walletAddress   String
  treeIndex       Int
  insertionIndex  Int
  amount          Float
  currency        String
  usdValue        Float
  sender          String?
  age             String?
  unlockerType    String?
  status          String   @default("claimable") // claimable | claiming | claimed | claim_failed
  claimTxSignature String?
  claimError      String?
  claimedAt       DateTime?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([merchantId, network, walletAddress, treeIndex, insertionIndex])
  @@index([merchantId, status])
  @@index([walletAddress, status])
}

// ─── Payroll (public → employee ETA via Umbra deposit) ───────────────────────
model PayrollRun {
  id              String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  memo            String
  currency        String // USDC | USDT
  category        String?
  status          String // draft | awaiting_delegation | processing | completed | partial | failed
  recipientCount  Int
  successCount    Int
  totalAmount     Float // sum of successfully deposited amounts (display units)
  /// Privy policy attached before wallet delegation (server-signed payroll).
  privyPolicyId   String?
  createdAt       DateTime @default(now())

  items PayrollRunItem[]

  @@index([merchantId, createdAt])
}

model PayrollRunItem {
  id                 String     @id @default(cuid())
  runId              String
  run                PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  destinationAddress String
  amount             Float
  status             String // pending | completed | failed
  txHash             String?
  error              String?

  @@index([runId])
}

// ─── Dashboard Event Stream ───────────────────────────────────────────────────
// Unified activity log for analytics/recent activity charts and feed.
model DashboardEvent {
  id           String   @id @default(cuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network       String
  walletAddress String?
  category      String   // payment | transfer | claim | shield | unshield | payroll | invoice | tiplinks | compliance
  direction     String   @default("in") // in | out
  status        String   @default("completed") // completed | pending | failed
  amount        Float
  currency      String
  counterparty  String?
  memo          String?
  txHash        String?
  metadata      String?
  createdAt     DateTime @default(now())

  @@index([merchantId, createdAt])
  @@index([merchantId, category])
}
